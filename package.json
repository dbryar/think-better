{
  "name": "how-to-question-power",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "lint": "bun run validate",
    "check": "bun run typecheck",
    "typecheck": "vue-tsc --noEmit",
    "validate": "tsx scripts/validate-content.ts",
    "build": "vite build",
    "export:pdf": "tsx scripts/export-pdf.ts",
    "manifest": "tsx scripts/generate-manifest.ts",
    "ci": "bun run lint && bun run check && bun run build && bun run export:pdf && bun run manifest"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "vite": "^6.3.5",
    "vue": "^3.5.16",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/markdown-it": "^14.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vue-tsc": "^2.2.10",
    "wrangler": "^4.20.5"
  }
}
