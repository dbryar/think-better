{
  "name": "how-to-question-power",
  "version": "0.1.0",
  "license": "CC-BY-SA-4.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run ci && wrangler pages dev dist --port=8788",
    "vite:dev": "vite --host 0.0.0.0",
    "lint": "bun run validate",
    "check": "bun run typecheck",
    "typecheck": "vue-tsc --noEmit",
    "validate": "tsx scripts/validate-content.ts",
    "build": "vite build",
    "export:pdf": "tsx scripts/export-pdf.ts",
    "manifest": "tsx scripts/generate-manifest.ts",
    "ci": "bun run lint && bun run check && bun run build && bun run export:pdf && bun run manifest"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.5",
    "vite": "^6.3.5",
    "vue": "^3.5.16",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vue-tsc": "^2.2.10",
    "wrangler": "^4.20.5"
  }
}
